generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DateCategory {
  LECTURE
  HOLIDAY
  DEADLINE
  EXAM
  OTHER
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum ExamType {
  QUIZ
  MIDTERM
  FINAL
  OTHER
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  name        String?
  syllabi     Syllabus[]
  studyPlans  StudyPlan[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Syllabus {
  id             String           @id @default(cuid())
  userId         String?
  title          String
  courseCode     String?
  instructor     String?
  term           String?
  sourceName     String?
  sourceText     String?
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  courseSummary  CourseSummary?
  topics         Topic[]
  importantDates ImportantDate[]
  assignments    Assignment[]
  exams          Exam[]
  studyPlans     StudyPlan[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
}

model CourseSummary {
  id          String   @id @default(cuid())
  syllabusId  String   @unique
  overview    String
  objectives  String[]
  workload    String?
  grading     Json?
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Topic {
  id          String   @id @default(cuid())
  syllabusId  String
  title       String
  description String?
  week        Int?
  order       Int      @default(0)
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([syllabusId])
}

model ImportantDate {
  id          String       @id @default(cuid())
  syllabusId  String
  title       String
  date        DateTime
  category    DateCategory @default(OTHER)
  notes       String?
  syllabus    Syllabus     @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([syllabusId])
  @@index([date])
}

model Assignment {
  id          String           @id @default(cuid())
  syllabusId  String
  title       String
  description String?
  dueDate     DateTime?
  points      Float?
  weight      Float?
  status      AssignmentStatus @default(NOT_STARTED)
  syllabus    Syllabus         @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([syllabusId])
  @@index([dueDate])
}

model Exam {
  id          String   @id @default(cuid())
  syllabusId  String
  title       String
  examType    ExamType @default(OTHER)
  date        DateTime?
  location    String?
  weight      Float?
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([syllabusId])
  @@index([date])
}

model StudyPlan {
  id          String   @id @default(cuid())
  syllabusId  String
  userId      String?
  title       String
  startsAt    DateTime?
  endsAt      DateTime?
  plan        Json
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([syllabusId])
  @@index([userId])
}
