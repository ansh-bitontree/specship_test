generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ApiRequestStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model ChatHistory {
  id           String        @id @default(cuid())
  title        String?
  messages     Message[]
  userSettings UserSettings?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Message {
  id            String       @id @default(cuid())
  chatHistoryId String
  role          MessageRole
  content       String
  metadata      Json?
  chatHistory   ChatHistory  @relation(fields: [chatHistoryId], references: [id], onDelete: Cascade)
  apiRequest    ApiRequest?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([chatHistoryId])
  @@index([createdAt])
}

model ApiRequest {
  id          String           @id @default(cuid())
  messageId   String           @unique
  provider    String?
  model       String?
  endpoint    String
  method      String           @default("POST")
  requestBody Json?
  status      ApiRequestStatus @default(PENDING)
  message     Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  response    ApiResponse?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
}

model ApiResponse {
  id            String     @id @default(cuid())
  apiRequestId  String     @unique
  statusCode    Int?
  responseBody  Json?
  error         String?
  durationMs    Int?
  apiRequest    ApiRequest @relation(fields: [apiRequestId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
}

model UserSettings {
  id             String      @id @default(cuid())
  chatHistoryId  String      @unique
  preferredModel String?
  systemPrompt   String?
  temperature    Float?
  settings       Json?
  chatHistory    ChatHistory @relation(fields: [chatHistoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}
